<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Revival TVPass - Homepage</title>
  
  <!-- Modern Font & Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <style>
    :root {
      --bg-dark: #0f0f12;
      --bg-card: #1a1a24;
      --accent-color: #3b82f6;
      --text-main: #f3f4f6;
      --text-muted: #9ca3af;
    }

    body {
      margin: 0;
      padding: 0;
      background-color: var(--bg-dark);
      color: var(--text-main);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      display: flex;
    }

    /* Sidebar Layout */
    .sidebar {
      width: 240px;
      height: 100vh;
      background-color: #16161e;
      position: fixed;
      top: 0;
      left: 0;
      display: flex;
      flex-direction: column;
      border-right: 1px solid #27273a;
    }

    .brand {
      padding: 24px;
      font-size: 1.2rem;
      font-weight: bold;
      color: var(--accent-color);
      display: flex;
      align-items: center;
      gap: 10px;
      border-bottom: 1px solid #27273a;
    }

    .nav-links {
      list-style: none;
      padding: 20px 0;
      margin: 0;
    }

    .nav-links li a {
      display: flex;
      align-items: center;
      gap: 15px;
      padding: 14px 24px;
      color: var(--text-muted);
      text-decoration: none;
      transition: all 0.2s ease;
    }

    .nav-links li a:hover, .nav-links li.active a {
      color: var(--text-main);
      background-color: #222230;
      border-left: 4px solid var(--accent-color);
    }

    /* Main Dashboard Area */
    .main-content {
      margin-left: 240px;
      padding: 40px;
      width: calc(100% - 240px);
      box-sizing: border-box;
    }

    .header-banner {
      background: linear-gradient(135deg, #1e1b4b 0%, #311042 100%);
      padding: 30px;
      border-radius: 12px;
      margin-bottom: 40px;
      border: 1px solid #3c1e5a;
    }

    .header-banner h1 {
      margin: 0 0 10px 0;
      font-size: 2rem;
    }

    .header-banner p {
      margin: 0;
      color: var(--text-muted);
    }

    /* Channels Grid */
    .section-title {
      font-size: 1.3rem;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .channel-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 20px;
    }

    /* Interactive Channel Card */
    .channel-card {
      background-color: var(--bg-card);
      border-radius: 10px;
      overflow: hidden;
      border: 1px solid #27273a;
      text-decoration: none;
      color: inherit;
      transition: transform 0.2s ease, border-color 0.2s ease;
    }

    .channel-card:hover {
      transform: translateY(-5px);
      border-color: var(--accent-color);
    }

    .logo-container {
      height: 120px;
      background-color: #111116;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .logo-container img {
      max-width: 100%;
      max-height: 100%;
      object-fit: contain;
    }

    .channel-info {
      padding: 15px;
    }

    .channel-name {
      font-weight: 600;
      font-size: 1rem;
      margin-bottom: 4px;
    }

    .channel-status {
      font-size: 0.8rem;
      color: #10b981; /* Green status color */
      display: flex;
      align-items: center;
      gap: 5px;
    }
  </style>
</head>
<body>

  <!-- Left Navigation Sidebar -->
  <aside class="sidebar">
    <div class="brand">
      <i class="fa-solid fa-tv"></i> Revival TVPass
    </div>
    <ul class="nav-links">
      <li class="active"><a href="#"><i class="fa-solid fa-house"></i> Home</a></li>
      <li><a href="player.html"><i class="fa-solid fa-play"></i> Live Player</a></li>
      <li><a href="https://github.com/Armond452Alt/fixed-m3u" target="_blank"><i class="fa-brands fa-github"></i> M3U Repo</a></li>
    </ul>
  </aside>

  <!-- Main Grid Layout -->
  <main class="main-content">
    <section class="header-banner">
      <h1>Welcome to the Revival</h1>
      <p>Clean, fixed, and community-maintained live TV layouts. Select a channel below to launch the video runtime.</p>
    </section>

    <h2 class="section-title"><i class="fa-solid fa-bolt" style="color: #eab308;"></i> Featured Channels</h2>
    
    <div class="channel-grid">
      
      <!-- Cartoon Network Card -->
      <a href="player.html?channel=cn_as" class="channel-card">
        <div class="logo-container">
          <img src="https://upload.wikimedia.org/wikipedia/commons/b/bb/Cartoon_Network_2010_logo.svg" alt="CN">
        </div>
        <div class="channel-info">
          <div class="channel-name">Cartoon Network / AS</div>
          <div class="channel-status"><i class="fa-solid fa-circle-check"></i> Live Stream</div>
        </div>
      </a>

      <!-- Nicktoons Card -->
      <a href="player.html?channel=nicktoons" class="channel-card">
        <div class="logo-container">
          <!-- Temporary placeholder icon - swap out for your clean local repo asset paths -->
          <img src="https://upload.wikimedia.org/wikipedia/commons/e/e4/Nicktoons_2009_logo.svg" alt="Nicktoons">
        </div>
        <div class="channel-info">
          <div class="channel-name">Nicktoons HD</div>
          <div class="channel-status"><i class="fa-solid fa-circle-check"></i> Live Stream</div>
        </div>
      </a>

    </div>
  </main>

</body>
</html>
